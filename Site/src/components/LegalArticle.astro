---
interface Props {
  title: string;
  updated?: string;
}

const { title, updated } = Astro.props;
---

<main class="legal-shell">
  <article class="legal">
    <p class="kicker">Moss</p>
    <h1>{title}</h1>
    {updated && <p class="updated">Last updated: {updated}</p>}
    <slot />
  </article>
</main>
