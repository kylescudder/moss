<section class="support-section" id="support" aria-labelledby="support-title">
  <div>
    <p class="kicker">Support / App Store compliance</p>
    <h2 id="support-title">Help, privacy, and terms for Moss.</h2>
    <p class="lede">
      Questions, account requests, subscription issues, bug reports, and
      feedback are handled by email. Include the email address on your Moss
      account and a short description of what you need help with.
    </p>
  </div>
  <div class="support-actions">
    <a
      class="button button-moss"
      href="mailto:support@getmoss.app?subject=Moss%20Support"
      >Email support</a
    >
    <a class="button button-stone" href="/privacy">Privacy policy</a>
    <a class="button button-stone" href="/terms">Terms of Use</a>
  </div>
</section>
